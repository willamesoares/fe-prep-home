---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Propose from '@/components/Propose';
import { TAGS } from '@/lib/constants';

const entries = await getCollection('questions');
const usedTags = Array.from(
  new Set([...TAGS, ...entries.flatMap((e) => e.data.tags as string[])]),
).sort((a, b) => {
  const ai = TAGS.indexOf(a as any);
  const bi = TAGS.indexOf(b as any);
  if (ai !== -1 && bi !== -1) return ai - bi;
  if (ai !== -1) return -1;
  if (bi !== -1) return 1;
  return a.localeCompare(b);
});
---

<Base title="Propose a question" description="Submit a new frontend interview question.">
  <section style="padding: 2rem 0 0.5rem">
    <h1>Propose a question</h1>
    <p style="color: var(--fg-muted); margin: 0 0 1rem">
      Sign in with GitHub. Your submission becomes a pull request a maintainer reviews and merges.
      Until that happens it won't appear on the site.
    </p>
  </section>
  <Propose client:only="preact" suggestedTags={usedTags} />
</Base>
