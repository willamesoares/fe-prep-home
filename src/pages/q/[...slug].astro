---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { renderMarkdown } from '@/lib/renderMarkdown';

export async function getStaticPaths() {
  const entries = await getCollection('questions');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'questions'>;
}

const { entry } = Astro.props as Props;
const body = (entry as unknown as { body?: string }).body ?? '';

const ANSWER_HEADING = /^#\s+Answer\s*$/m;
const QUESTION_HEADING = /^#\s+Question\s*$/m;

const m = body.match(ANSWER_HEADING);
const questionMd = (m && m.index !== undefined
  ? body.slice(0, m.index)
  : body
).replace(QUESTION_HEADING, '').trim();
const answerMd = m && m.index !== undefined ? body.slice(m.index + m[0].length).trim() : '';

const [questionHtml, answerHtml] = await Promise.all([
  renderMarkdown(questionMd),
  renderMarkdown(answerMd),
]);
---

<Base title={entry.data.title} description={entry.data.title}>
  <article class="question-detail">
    <a href="/" style="font-size: 0.9rem; color: var(--fg-muted)">← All questions</a>
    <h1 style="margin-top: 0.5rem">{entry.data.title}</h1>
    <div class="meta">
      <span class={`difficulty ${entry.data.difficulty}`}>{entry.data.difficulty}</span>
      {entry.data.tags.map((t) => <span class="tag-chip">{t}</span>)}
    </div>
    <div class="qa-content" set:html={questionHtml} />
    {answerHtml && (
      <details class="answer-toggle">
        <summary>Show answer</summary>
        <div class="qa-content" set:html={answerHtml} />
      </details>
    )}
    <p style="margin-top: 2rem; color: var(--fg-muted); font-size: 0.9rem">
      Spotted something wrong? <a href={`/propose?edit=${entry.id}`}>Propose an edit on GitHub</a>.
    </p>
  </article>
</Base>
